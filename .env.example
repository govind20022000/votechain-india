# VoteChain India — Environment Variables
# Copy to .env and fill in. All values are OPTIONAL — the app falls back to demo OTP `123456`.

# Base URL for mobile OTP backend (POST /send-otp, /verify-otp)
VITE_API_URL=

# Base URL for email OTP backend (POST /send-email-otp, /verify-email-otp)
VITE_EMAIL_API=
